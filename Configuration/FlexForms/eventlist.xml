<?xml version="1.0" encoding="utf-8"?>
<T3DataStructure>
    <sheets>
        <general>
            <ROOT>
                    <sheetTitle>LLL:EXT:rescue_reports/Resources/Private/Language/locallang_db.xlf:sheet.general</sheetTitle>
                <type>array</type>
                <el>

                    <settings.templateVariant>
                            <label>LLL:EXT:rescue_reports/Resources/Private/Language/locallang_db.xlf:templateVariant</label>
                            <config>
                                <type>select</type>
                                <renderType>selectSingle</renderType>
                                <items>
                                    <numIndex index="0">
                                        <numIndex index="0">Bootstrap</numIndex>
                                        <numIndex index="1">bootstrap</numIndex>
                                    </numIndex>
                                    <numIndex index="1">
                                        <numIndex index="0">Foundation</numIndex>
                                        <numIndex index="1">foundation</numIndex>
                                    </numIndex>
                                </items>
                                <default>bootstrap</default>
                            </config>
                    </settings.templateVariant>

                    <settings.defaultStation>
                            <label>LLL:EXT:rescue_reports/Resources/Private/Language/locallang_db.xlf:defaultStation</label>
                            <config>
                                <type>select</type>
                                <renderType>selectSingle</renderType>
                                <itemsProcFunc>nkfire\RescueReports\UserFunctions\FlexFormStationItems->addPrimaryStations</itemsProcFunc>
                                <items>
                                    <numIndex index="0">
                                        <numIndex index="0">-- keine Auswahl --</numIndex>
                                        <numIndex index="1">0</numIndex>
                                    </numIndex>
                                </items>
                                <minitems>0</minitems>
                                <maxitems>1</maxitems>
                                <size>1</size>
                            </config>
                    </settings.defaultStation>

                    <settings.showStationFilter>
                            <label>LLL:EXT:rescue_reports/Resources/Private/Language/locallang_db.xlf:showStationFilter</label>
                            <config>
                                <type>check</type>
                                <items>
                                    <numIndex index="0">
                                        <numIndex index="0">Ja</numIndex>
                                    </numIndex>
                                </items>
                                <default>1</default>
                            </config>
                    </settings.showStationFilter>

                    <settings.maxCount>
                            <label>LLL:EXT:rescue_reports/Resources/Private/Language/locallang_db.xlf:maxCount</label>
                            <config>
                                <type>input</type>
                                <eval>int</eval>
                                <size>5</size>
                                <default>0</default>
                            </config>
                    </settings.maxCount>

                    <settings.dateFrom>
                            <label>LLL:EXT:rescue_reports/Resources/Private/Language/locallang_db.xlf:dateFrom</label>
                            <config>
                                <type>input</type>
                                <renderType>inputDateTime</renderType>
                                <eval>date</eval>
                            </config>
                    </settings.dateFrom>

                    <settings.dateTo>
                            <label>LLL:EXT:rescue_reports/Resources/Private/Language/locallang_db.xlf:dateTo</label>
                            <config>
                                <type>input</type>
                                <renderType>inputDateTime</renderType>
                                <eval>date</eval>
                            </config>
                    </settings.dateTo>

                    <settings.enableSearch>
                            <label>LLL:EXT:rescue_reports/Resources/Private/Language/locallang_db.xlf:enableSearch</label>
                            <config>
                                <type>check</type>
                                <items>
                                    <numIndex index="0">
                                        <numIndex index="0">Ja</numIndex>
                                    </numIndex>
                                </items>
                            </config>
                    </settings.enableSearch>

                    <settings.detailPageUid>
                            <label>LLL:EXT:rescue_reports/Resources/Private/Language/locallang_db.xlf:detailPageUid</label>
                            <config>
                                <type>group</type>
                                <internal_type>db</internal_type>
                                <allowed>pages</allowed>
                                <size>1</size>
                                <minitems>1</minitems>
                                <maxitems>1</maxitems>
                            </config>
                    </settings.detailPageUid>

                    <settings.enableDateFilter>
                            <label>Datumsfilter im Frontend anzeigen</label>
                            <config>
                                <type>check</type>
                                <items>
                                    <numIndex index="0">
                                        <numIndex index="0">Ja</numIndex>
                                    </numIndex>
                                </items>
                                <default>0</default>
                            </config>
                    </settings.enableDateFilter>

                    <settings.enableYearFilter>
                            <label>Jahresfilter anzeigen</label>
                            <config>
                                <type>check</type>
                                <items>
                                    <numIndex index="0">
                                        <numIndex index="0">Ja</numIndex>
                                    </numIndex>
                                </items>
                                <default>1</default>
                            </config>
                    </settings.enableYearFilter>

                    <settings.yearFilterDefault>
                            <label>Jahresfilter: Standardauswahl beim ersten Aufruf</label>
                            <config>
                                <type>select</type>
                                <renderType>selectSingle</renderType>
                                <items>
                                    <numIndex index="0">
                                        <numIndex index="0">Alle Jahre</numIndex>
                                        <numIndex index="1">all</numIndex>
                                    </numIndex>
                                    <numIndex index="1">
                                        <numIndex index="0">Aktuelles Jahr</numIndex>
                                        <numIndex index="1">current</numIndex>
                                    </numIndex>
                                </items>
                                <default>all</default>
                            </config>
                    </settings.yearFilterDefault>

                    <settings.statisticsYears>
                            <label>Statistik: Anzahl angezeigter Jahre (0 = alle)</label>
                            <config>
                                <type>input</type>
                                <eval>int</eval>
                                <size>5</size>
                                <default>0</default>
                                <placeholder>0 = alle Jahre</placeholder>
                            </config>
                    </settings.statisticsYears>

                    <settings.showStatistics>
                            <label>Statistik anzeigen</label>
                            <config>
                                <type>check</type>
                                <items>
                                    <numIndex index="0">
                                        <numIndex index="0">Ja</numIndex>
                                    </numIndex>
                                </items>
                                <default>0</default>
                            </config>
                    </settings.showStatistics>

                    <settings.statisticsPosition>
                            <label>Position der Statistik</label>
                            <config>
                                <type>select</type>
                                <renderType>selectSingle</renderType>
                                <items>
                                    <numIndex index="0">
                                        <numIndex index="0">Unterhalb der Einsatzliste</numIndex>
                                        <numIndex index="1">below</numIndex>
                                    </numIndex>
                                    <numIndex index="1">
                                        <numIndex index="0">Oberhalb der Einsatzliste</numIndex>
                                        <numIndex index="1">above</numIndex>
                                    </numIndex>
                                </items>
                                <default>below</default>
                            </config>
                    </settings.statisticsPosition>

                    <settings.showMapView>
                            <label>Kartenansicht anzeigen</label>
                            <config>
                                <type>check</type>
                                <items>
                                    <numIndex index="0">
                                        <numIndex index="0">Ja</numIndex>
                                    </numIndex>
                                </items>
                                <default>0</default>
                            </config>
                    </settings.showMapView>

                    <settings.mapHeight>
                            <label>Kartenhöhe in Pixeln</label>
                            <config>
                                <type>input</type>
                                <eval>int</eval>
                                <size>6</size>
                                <default>400</default>
                                <placeholder>400</placeholder>
                            </config>
                    </settings.mapHeight>

                    <settings.mapZoom>
                            <label>Standard-Zoomstufe (1–19)</label>
                            <config>
                                <type>input</type>
                                <eval>int</eval>
                                <size>4</size>
                                <default>11</default>
                            </config>
                    </settings.mapZoom>

                    <settings.mapPosition>
                            <label>Position der Karte</label>
                            <config>
                                <type>select</type>
                                <renderType>selectSingle</renderType>
                                <items>
                                    <numIndex index="0">
                                        <numIndex index="0">Unterhalb der Einsatzliste</numIndex>
                                        <numIndex index="1">below</numIndex>
                                    </numIndex>
                                    <numIndex index="1">
                                        <numIndex index="0">Oberhalb der Einsatzliste</numIndex>
                                        <numIndex index="1">above</numIndex>
                                    </numIndex>
                                </items>
                                <default>below</default>
                            </config>
                    </settings.mapPosition>

                </el>
            </ROOT>
        </general>
    </sheets>
</T3DataStructure>
