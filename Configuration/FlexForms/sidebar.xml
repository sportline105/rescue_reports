<?xml version="1.0" encoding="utf-8"?>
<T3DataStructure>
    <sheets>
        <general>
            <ROOT>
                    <sheetTitle>LLL:EXT:rescue_reports/Resources/Private/Language/locallang_db.xlf:sheet.sidebar</sheetTitle>
                <type>array</type>
                <el>

                    <settings.widgetTitle>
                            <label>LLL:EXT:rescue_reports/Resources/Private/Language/locallang_db.xlf:widgetTitle</label>
                            <config>
                                <type>input</type>
                                <eval>trim</eval>
                                <placeholder>Letzte Einsätze</placeholder>
                            </config>
                    </settings.widgetTitle>

                    <settings.defaultStation>
                            <label>LLL:EXT:rescue_reports/Resources/Private/Language/locallang_db.xlf:defaultStationSidebar</label>
                            <config>
                                <type>select</type>
                                <renderType>selectSingle</renderType>
                                <itemsProcFunc>nkfire\RescueReports\UserFunctions\FlexFormStationItems->addPrimaryStations</itemsProcFunc>
                                <items>
                                    <numIndex index="0">
                                        <numIndex index="0">-- alle Ortsfeuerwehren --</numIndex>
                                        <numIndex index="1">0</numIndex>
                                    </numIndex>
                                </items>
                                <minitems>0</minitems>
                                <maxitems>1</maxitems>
                                <size>1</size>
                            </config>
                    </settings.defaultStation>

                    <settings.maxCount>
                            <label>LLL:EXT:rescue_reports/Resources/Private/Language/locallang_db.xlf:maxCountSidebar</label>
                            <config>
                                <type>input</type>
                                <eval>int</eval>
                                <size>5</size>
                                <default>5</default>
                                <placeholder>5</placeholder>
                            </config>
                    </settings.maxCount>

                    <settings.templateVariant>
                            <label>LLL:EXT:rescue_reports/Resources/Private/Language/locallang_db.xlf:templateVariantSidebar</label>
                            <config>
                                <type>select</type>
                                <renderType>selectSingle</renderType>
                                <items>
                                    <numIndex index="0">
                                        <numIndex index="0">Bootstrap</numIndex>
                                        <numIndex index="1">sidebar-bootstrap</numIndex>
                                    </numIndex>
                                    <numIndex index="1">
                                        <numIndex index="0">Foundation</numIndex>
                                        <numIndex index="1">sidebar-foundation</numIndex>
                                    </numIndex>
                                </items>
                                <default>sidebar-bootstrap</default>
                            </config>
                    </settings.templateVariant>

                    <settings.detailPageUid>
                            <label>LLL:EXT:rescue_reports/Resources/Private/Language/locallang_db.xlf:detailPageUidSidebar</label>
                            <config>
                                <type>group</type>
                                <internal_type>db</internal_type>
                                <allowed>pages</allowed>
                                <size>1</size>
                                <minitems>0</minitems>
                                <maxitems>1</maxitems>
                            </config>
                    </settings.detailPageUid>

                    <settings.listPageUid>
                            <label>LLL:EXT:rescue_reports/Resources/Private/Language/locallang_db.xlf:listPageUidSidebar</label>
                            <config>
                                <type>group</type>
                                <internal_type>db</internal_type>
                                <allowed>pages</allowed>
                                <size>1</size>
                                <minitems>0</minitems>
                                <maxitems>1</maxitems>
                            </config>
                    </settings.listPageUid>

                </el>
            </ROOT>
        </general>
    </sheets>
</T3DataStructure>
