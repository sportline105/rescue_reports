<?xml version="1.0" encoding="utf-8"?>
<T3DataStructure>
    <sheets>
        <general>
            <ROOT>
                <TCEforms>
                    <sheetTitle>Statistik</sheetTitle>
                </TCEforms>
                <type>array</type>
                <el>

                    <settings.station>
                        <TCEforms>
                            <label>Ortsfeuerwehr (Filter)</label>
                            <config>
                                <type>select</type>
                                <renderType>selectSingle</renderType>
                                <itemsProcFunc>Nkfire\RescueReports\UserFunctions\FlexFormStationItems->addPrimaryStations</itemsProcFunc>
                                <items>
                                    <numIndex index="0">
                                        <numIndex index="0">– Alle Ortsfeuerwehren –</numIndex>
                                        <numIndex index="1">0</numIndex>
                                    </numIndex>
                                </items>
                                <minitems>0</minitems>
                                <maxitems>1</maxitems>
                                <size>1</size>
                            </config>
                        </TCEforms>
                    </settings.station>

                    <settings.showStationFilter>
                        <TCEforms>
                            <label>Auswahl der Ortsfeuerwehr im Frontend anzeigen</label>
                            <config>
                                <type>check</type>
                                <items>
                                    <numIndex index="0">
                                        <numIndex index="0">Ja</numIndex>
                                    </numIndex>
                                </items>
                                <default>1</default>
                            </config>
                        </TCEforms>
                    </settings.showStationFilter>

                    <settings.statisticsYears>
                        <TCEforms>
                            <label>Anzahl angezeigter Jahre (0 = alle)</label>
                            <config>
                                <type>input</type>
                                <eval>int</eval>
                                <size>5</size>
                                <default>0</default>
                                <placeholder>0 = alle Jahre</placeholder>
                            </config>
                        </TCEforms>
                    </settings.statisticsYears>

                    <settings.showMonthlyChart>
                        <TCEforms>
                            <label>Monatsdiagramm anzeigen (Mehrjahresvergleich)</label>
                            <config>
                                <type>check</type>
                                <default>1</default>
                                <items>
                                    <numIndex index="0">
                                        <numIndex index="0">Ja</numIndex>
                                        <numIndex index="1">1</numIndex>
                                    </numIndex>
                                </items>
                            </config>
                        </TCEforms>
                    </settings.showMonthlyChart>

                </el>
            </ROOT>
        </general>
    </sheets>
</T3DataStructure>
