<?xml version="1.0" encoding="utf-8"?>
<T3DataStructure>
    <sheets>
        <sDEF>
            <ROOT>
                <sheetTitle>LLL:EXT:rescue_reports/Resources/Private/Language/locallang_db.xlf:sheet.statistics</sheetTitle>
                <type>array</type>
                <el>

                    <settings.station>
                        <label>LLL:EXT:rescue_reports/Resources/Private/Language/locallang_db.xlf:statisticsStation</label>
                        <config>
                            <type>select</type>
                            <renderType>selectSingle</renderType>
                            <itemsProcFunc class="nkfire\RescueReports\UserFunctions\FlexFormStationItems" method="addPrimaryStations" />
                            <items>
                                <numIndex index="0">
                                    <label>– Alle Ortsfeuerwehren –</label>
                                    <value>0</value>
                                </numIndex>
                            </items>
                            <minitems>0</minitems>
                            <maxitems>1</maxitems>
                            <size>1</size>
                        </config>
                    </settings.station>

                    <settings.showStationFilter>
                        <label>LLL:EXT:rescue_reports/Resources/Private/Language/locallang_db.xlf:showStationFilterStats</label>
                        <config>
                            <type>check</type>
                            <items>
                                <numIndex index="0">
                                    <label>Ja</label>
                                    <value>1</value>
                                </numIndex>
                            </items>
                            <default>1</default>
                        </config>
                    </settings.showStationFilter>

                    <settings.statisticsYears>
                        <label>LLL:EXT:rescue_reports/Resources/Private/Language/locallang_db.xlf:statisticsYears</label>
                        <config>
                            <type>number</type>
                            <size>5</size>
                            <default>0</default>
                        </config>
                    </settings.statisticsYears>

                    <settings.showMonthlyChart>
                        <label>LLL:EXT:rescue_reports/Resources/Private/Language/locallang_db.xlf:showMonthlyChart</label>
                        <config>
                            <type>check</type>
                            <items>
                                <numIndex index="0">
                                    <label>Ja</label>
                                    <value>1</value>
                                </numIndex>
                            </items>
                            <default>1</default>
                        </config>
                    </settings.showMonthlyChart>

                </el>
            </ROOT>
        </sDEF>
    </sheets>
</T3DataStructure>
